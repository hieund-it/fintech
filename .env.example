# =============================================================================
# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.
# =============================================================================

# --- PostgreSQL (shared by all services) ---
POSTGRES_DB=vnstock
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# --- JWT (C# API) ---
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long

# --- SMTP / email alerts (C# API) ---
# Leave blank to disable email alerts.
SMTP_HOST=smtp.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@vnstock.app

# --- Redis ---
# Leave blank if no Redis auth required.
REDIS_PASSWORD=

# --- Python vnstock-service ---
REDIS_URL=redis://localhost:6379
TCBS_POLL_INTERVAL=3
BATCH_PERSIST_INTERVAL=5
# Redis pub/sub channel prefix — must match Cors__Origins below and C# subscriber
REDIS_CHANNEL_PREFIX=ticks

# =============================================================================
# ASP.NET Core env-var overrides (double-underscore = config section separator)
# DotNetEnv loads these at startup; they override appsettings.Development.json.
# =============================================================================
ConnectionStrings__DefaultConnection=Host=localhost;Port=5433;Database=vnstock;Username=postgres;Password=change_me_strong_password
Jwt__Secret=your-super-secret-jwt-key-min-32-characters-long
Redis__ConnectionString=localhost:6379
Email__SmtpHost=smtp.brevo.com
Email__SmtpPort=587
Email__Username=
Email__Password=
Email__FromAddress=noreply@vnstock.app
# Comma-separated list of allowed CORS origins for the React dev server
Cors__Origins=http://localhost:5173,http://localhost:3000

# --- OAuth Providers ---
OAuth__Google__ClientId=
OAuth__Google__ClientSecret=
OAuth__GitHub__ClientId=
OAuth__GitHub__ClientSecret=
OAuth__FrontendCallbackUrl=http://localhost:5173/auth/callback
# Max SignalR symbol subscriptions per WebSocket connection
MarketHub__MaxSymbolsPerConnection=50
# How often (minutes) AlertEngineService reloads active alerts from DB
AlertEngine__ReloadIntervalMinutes=5
